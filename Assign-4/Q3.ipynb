   "source": [
    "def multiply_list(lst):\n",
    "    result = 1\n",
    "\n",
    "    for num in lst:\n",
    "        result = result * num\n",
    "\n",
    "    return result\n",
    "\n",
    "numbers = [2, 3, 4]\n",
    "\n",
    "print(\"Multiplication:\", multiply_list(numbers))"
   ]
  }
