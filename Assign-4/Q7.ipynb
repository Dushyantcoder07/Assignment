    "def even_numbers(lst):\n",
    "    print(\"Even Numbers:\")\n",
    "\n",
    "    for num in lst:\n",
    "        if num % 2 == 0:\n",
    "            print(num)\n",
    "\n",
    "numbers = [1, 2, 3, 4, 5, 6]\n",
    "\n",
    "even_numbers(numbers)"
   ]
