    "def distinct_list(lst):\n",
    "    return list(set(lst))\n",
    "\n",
    "numbers = [1, 2, 2, 3, 4, 4, 5]\n",
    "\n",
    "print(\"Distinct Elements:\", distinct_list(numbers))"
