   "source": [
    "def count_case(text):\n",
    "    upper = 0\n",
    "    lower = 0\n",
    "\n",
    "    for ch in text:\n",
    "        if ch.isupper():\n",
    "            upper += 1\n",
    "        elif ch.islower():\n",
    "            lower += 1\n",
    "\n",
    "    print(\"Uppercase Letters:\", upper)\n",
    "    print(\"Lowercase Letters:\", lower)\n",
    "\n",
    "count_case(\"Hello World\")"
   ]
  }
 ],
